# 仅作示例模板，勿填写真实密码/授权码（真实配置复制为 server/.env 后本地填写）
# 复制此文件为 .env：cp .env.example .env  （Windows 可手动复制重命名）

# 服务端口（默认 3030）
PORT=3030

# 监听地址：0.0.0.0 允许本机局域网 IP 访问；仅本机可改为 127.0.0.1
# HOST=0.0.0.0

# JWT 密钥（随机生成一段长字符串，不要泄露）
JWT_SECRET=请替换为随机长字符串

# SMTP（示例为 163，请把真实值只写在本地 .env，不要写进本文件）
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_smtp_authorization_code

# 简历数据存储目录（默认 ./data，可改为绝对路径）
# RESUME_DIR=C:/upload/resume-data
